<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/themeEditorTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:accessibilityHeading="true"
        android:text="@string/theme_editor_title"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

    <RadioGroup
        android:id="@+id/themeModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/themeModeLight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_mode_light" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/themeModeDark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_mode_dark" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/themeModeSystem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_mode_system" />
    </RadioGroup>

    <TextView
        android:id="@+id/accentPaletteTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/theme_accent_palette_title"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <RadioGroup
        android:id="@+id/accentPaletteGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentBlue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_blue" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentTeal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_teal" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentGreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_green" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentOrange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_orange" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentRed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_red" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/accentPink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_accent_pink" />
    </RadioGroup>

</LinearLayout>
