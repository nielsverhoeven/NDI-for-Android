<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settingsTopAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/settings_title" />

    <LinearLayout
        android:id="@+id/settingsCompactContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/settingsHeaderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/settingsHeaderTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:accessibilityHeading="true"
                android:text="@string/settings_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/developerModeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_developer_mode_label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveSettingsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_save_button" />

                    <TextView
                        android:id="@+id/settingsCompactSavedConfirmation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_validation_saved"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/compactAppearanceLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_detail_appearance_title"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                <RadioGroup
                    android:id="@+id/compactThemeModeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactThemeModeLight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_mode_light" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactThemeModeDark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_mode_dark" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactThemeModeSystem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_mode_system" />

                </RadioGroup>

                <TextView
                    android:id="@+id/compactAccentLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_accent_color_label"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                <RadioGroup
                    android:id="@+id/compactAccentGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentBlue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_blue" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentTeal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_teal" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentGreen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_green" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentOrange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_orange" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentRed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_red" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/compactAccentPink"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_accent_pink" />

                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openDiscoveryServersButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/discovery_servers_open_button" />

                <TextView
                    android:id="@+id/fallbackWarningMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Wide two-column layout (tablet / landscape mode).
         Column 1 (weight=1, 1/3): settings category menu.
         Column 2 (weight=2, 2/3): adjustable settings for the selected category. -->
    <LinearLayout
        android:id="@+id/settingsTwoColumnContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="3">

        <!-- Column 1: Settings category menu (1/3 width) -->
        <LinearLayout
            android:id="@+id/settingsMenuPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:accessibilityHeading="true"
                android:paddingBottom="8dp"
                android:text="@string/settings_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/settingsCategoriesList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:contentDescription="@string/settings_title"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

        </LinearLayout>

        <!-- Column 2: Adjustable settings for the selected category (2/3 width) -->
        <LinearLayout
            android:id="@+id/settingsDetailPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:weightSum="1">

            <!-- Back toolbar shown in phone-portrait mode when a detail page is open.
                 Hidden in wide (tablet/landscape) mode. -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/settingsDetailToolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:navigationIcon="@drawable/ic_back"
                app:navigationContentDescription="@string/settings_back_content_description" />

            <!-- Normal detail content (shown for all categories except Discovery) -->
            <LinearLayout
                android:id="@+id/settingsDetailNormalContent"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/settingsDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:accessibilityHeading="true"
                    android:paddingBottom="8dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                <ScrollView
                    android:id="@+id/settingsDetailScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:scrollbars="vertical">

                    <LinearLayout
                        android:id="@+id/settingsDetailContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </ScrollView>

                <TextView
                    android:id="@+id/settingsDetailEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:visibility="gone" />

                <!-- Apply bar: button is disabled until settings are changed; confirmation appears after save -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settingsApplyButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:text="@string/settings_apply_button" />

                    <TextView
                        android:id="@+id/settingsSavedConfirmation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_validation_saved"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Discovery inline container (shown only when Discovery category is selected) -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/settingsDiscoveryContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
