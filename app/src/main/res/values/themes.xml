<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NdiApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="colorSurface">@color/fluent_electron_surface_root</item>
        <item name="colorSurfaceContainer">@color/fluent_electron_surface_card</item>
        <item name="android:textColorPrimary">@color/fluent_electron_text_primary</item>
        <item name="android:textColorSecondary">@color/fluent_electron_text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.NdiApp.Button</item>
    </style>

    <style name="Theme.NDIforAndroid" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- =========================================================
         Accent theme overlays – light mode (applied before setContentView)
         Primary roles  : buttons, FABs, sliders, checkboxes, switches
         Secondary roles: navigation bar/rail selected indicator & icon
         ========================================================= -->

