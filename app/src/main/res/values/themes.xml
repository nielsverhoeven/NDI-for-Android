    <style name="TextAppearance.NdiApp.FluentElectron.Heading" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/fluent_electron_text_primary</item>
    </style>

    <style name="TextAppearance.NdiApp.FluentElectron.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/fluent_electron_text_secondary</item>
    </style>

    <style name="TextAppearance.NdiApp.FluentElectron.StatusPositive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/fluent_electron_state_success</item>
    </style>

    <style name="TextAppearance.NdiApp.FluentElectron.StatusWarning" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/fluent_electron_state_warning</item>
    </style>

    <style name="TextAppearance.NdiApp.FluentElectron.StatusNegative" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/fluent_electron_state_error</item>
    </style>

    <style name="ShapeAppearance.NdiApp.Button" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">@dimen/ndi_button_corner_radius</item>
    </style>

    <style name="Widget.NdiApp.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.NdiApp.Button</item>
    </style>

    <style name="Widget.NdiApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearance">@style/ShapeAppearance.NdiApp.Button</item>
    </style>

    <style name="Widget.NdiApp.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="shapeAppearance">@style/ShapeAppearance.NdiApp.Button</item>
    </style>

</resources>
