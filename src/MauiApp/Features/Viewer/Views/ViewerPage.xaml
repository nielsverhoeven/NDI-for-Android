<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NdiForAndroid.Features.Viewer.ViewModels;assembly=NdiForAndroid.Core"
             x:Class="NdiForAndroid.Features.Viewer.Views.ViewerPage"
             x:DataType="vm:ViewerViewModel"
             Title="Viewer">
    <VerticalStackLayout Padding="16" Spacing="16">
        <Label Text="{Binding StatusMessage}" HorizontalOptions="Center" />
        <Button Text="Stop" Command="{Binding StopCommand}"
                IsVisible="{Binding IsPlaying}" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
