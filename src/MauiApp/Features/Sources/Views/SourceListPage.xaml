<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NdiForAndroid.Features.Sources.ViewModels;assembly=NdiForAndroid.Core"
             xmlns:models="clr-namespace:NdiForAndroid.Features.Sources.Models;assembly=NdiForAndroid.Core"
             x:Class="NdiForAndroid.Features.Sources.Views.SourceListPage"
             x:DataType="vm:SourceListViewModel"
             Title="NDI Sources">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <CollectionView ItemsSource="{Binding Sources}"
                        EmptyView="No NDI sources found. Pull to refresh.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NdiSource">
                    <Grid Padding="16,8" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="{Binding DisplayName}"
                                   FontAttributes="Bold"
                                   FontSize="16" />
                            <Label Text="{Binding EndpointAddress}"
                                   FontSize="12"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Button Text="Watch"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SourceListViewModel}}, Path=NavigateToViewerCommand}"
                                    CommandParameter="{Binding .}" />
                            <Button Text="Output"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SourceListViewModel}}, Path=NavigateToOutputCommand}"
                                    CommandParameter="{Binding .}" />
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>

</ContentPage>
