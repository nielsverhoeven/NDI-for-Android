<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NdiForAndroid.Features.Settings.ViewModels;assembly=NdiForAndroid.Core"
             xmlns:model="clr-namespace:NdiForAndroid.Features.Settings.Models;assembly=NdiForAndroid.Core"
             x:Class="NdiForAndroid.Features.Settings.Views.SettingsPage"
             x:Name="SettingsRoot"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">
    <Grid>
        <ScrollView>
              <Grid Padding="16" ColumnDefinitions="220,*" ColumnSpacing="16">
                     <VerticalStackLayout Grid.Column="0" Spacing="10">
                            <Button Text="General"
                                          Command="{Binding SelectSectionCommand}"
                                   CommandParameter="{x:Static vm:SettingsSection.General}" />
                            <Button Text="Appearance"
                                          Command="{Binding SelectSectionCommand}"
                                   CommandParameter="{x:Static vm:SettingsSection.Appearance}" />
                            <Button Text="Discovery"
                                          Command="{Binding SelectSectionCommand}"
                                   CommandParameter="{x:Static vm:SettingsSection.Discovery}" />
                            <Button Text="Developer tools"
                                          Command="{Binding SelectSectionCommand}"
                                   CommandParameter="{x:Static vm:SettingsSection.DeveloperTools}" />
                            <Button Text="About"
                                          Command="{Binding SelectSectionCommand}"
                                   CommandParameter="{x:Static vm:SettingsSection.About}" />
                     </VerticalStackLayout>

                     <VerticalStackLayout Grid.Column="1" Spacing="12">
                            <VerticalStackLayout IsVisible="{Binding IsGeneralSectionSelected}" Spacing="8">
                                   <Label Text="General Settings" FontAttributes="Bold" FontSize="20" />
                                   <Label Text="{Binding GeneralGuidanceText}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsAppearanceSectionSelected}" Spacing="10">
                                   <Label Text="Appearance Settings" FontAttributes="Bold" FontSize="20" />

                                   <Label Text="Theme" FontAttributes="Bold" />
                                   <VerticalStackLayout Spacing="4"
                                                                       RadioButtonGroup.GroupName="ThemeMode"
                                                                       RadioButtonGroup.SelectedValue="{Binding SelectedThemeOption}">
                                          <RadioButton Content="Light" Value="Light" />
                                          <RadioButton Content="Dark" Value="Dark" />
                                          <RadioButton Content="System default" Value="System default" />
                                   </VerticalStackLayout>

                                   <Label Text="Accent color" FontAttributes="Bold" />
                                   <FlexLayout Wrap="Wrap"
                                                        Direction="Row"
                                                        JustifyContent="Start"
                                                        AlignItems="Center"
                                                        RadioButtonGroup.GroupName="AccentColor"
                                                        RadioButtonGroup.SelectedValue="{Binding SelectedAccentColor}">
                                          <RadioButton Content="Blue" Value="Blue" Margin="0,0,16,0" />
                                          <RadioButton Content="Teal" Value="Teal" Margin="0,0,16,0" />
                                          <RadioButton Content="Green" Value="Green" Margin="0,0,16,0" />
                                          <RadioButton Content="Orange" Value="Orange" Margin="0,0,16,0" />
                                          <RadioButton Content="Red" Value="Red" Margin="0,0,16,0" />
                                          <RadioButton Content="Pink" Value="Pink" Margin="0,0,16,0" />
                                   </FlexLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsDiscoverySectionSelected}" Spacing="10">
                                   <Label Text="Discovery Settings" FontAttributes="Bold" FontSize="20" />

                                   <Label Text="Add discovery server" FontAttributes="Bold" />
                                   <Entry Placeholder="Display name (optional)"
                                             Text="{Binding NewServerDisplayName}" />
                                   <Entry Placeholder="Hostname or IP"
                                             Text="{Binding NewServerHost}"
                                             Keyboard="Url" />
                                   <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                          <Entry Grid.Column="0"
                                                    Placeholder="Port (default 5959)"
                                                    Text="{Binding NewServerPort}"
                                                    Keyboard="Numeric" />
                                          <Button Grid.Column="1"
                                                        Text="Add Server"
                                                        Command="{Binding AddDiscoveryServerCommand}" />
                                   </Grid>

                                   <Label Text="{Binding DiscoveryServersValidationMessage}"
                                             TextColor="{DynamicResource ErrorRed}" />

                                   <CollectionView ItemsSource="{Binding DiscoveryServers}">
                                          <CollectionView.ItemTemplate>
                                                 <DataTemplate x:DataType="vm:DiscoveryServerItem">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto" ColumnSpacing="8" Padding="0,4">
                                                               <Label Grid.Column="0"
                                                                          Text="●"
                                                                          FontSize="18"
                                                                          VerticalOptions="Center"
                                                                          TextColor="{Binding ConnectionState, Converter={StaticResource DiscoveryServerStateColorConverter}}" />
                                                               <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                                      <Label Text="{Binding NameDisplay}" FontAttributes="Bold" />
                                                                      <HorizontalStackLayout Spacing="8">
                                                                             <Label Text="{Binding EndpointDisplay}"
                                                                                       FontSize="12"
                                                                                       TextColor="{DynamicResource TextSecondary}" />
                                                                             <Label Text="{Binding ConnectionStateDisplay}"
                                                                                       FontSize="12"
                                                                                       TextColor="{DynamicResource TextSecondary}" />
                                                                      </HorizontalStackLayout>
                                                               </VerticalStackLayout>
                                                               <Switch Grid.Column="2" IsToggled="{Binding Enabled}" VerticalOptions="Center" />
                                                               <Button Grid.Column="3"
                                                                             Text="Up"
                                                                             Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.MoveDiscoveryServerUpCommand}"
                                                                             CommandParameter="{Binding .}" />
                                                               <Button Grid.Column="4"
                                                                             Text="Down"
                                                                             Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.MoveDiscoveryServerDownCommand}"
                                                                             CommandParameter="{Binding .}" />
                                                               <Button Grid.Column="5"
                                                                             Text="Edit"
                                                                             Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.EditDiscoveryServerCommand}"
                                                                             CommandParameter="{Binding .}" />
                                                               <Button Grid.Column="6"
                                                                             Text="Delete"
                                                                             Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.RemoveDiscoveryServerCommand}"
                                                                             CommandParameter="{Binding .}" />
                                                        </Grid>
                                                 </DataTemplate>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsDeveloperToolsSectionSelected}" Spacing="10">
                                   <Label Text="Developer Settings" FontAttributes="Bold" FontSize="20" />

                                   <HorizontalStackLayout Spacing="8">
                                          <Switch IsToggled="{Binding DeveloperModeEnabled}" />
                                          <Label Text="Developer Mode" VerticalOptions="Center" />
                                   </HorizontalStackLayout>

                                   <Label Text="Cached Source Registry" FontAttributes="Bold" />
                                   <CollectionView ItemsSource="{Binding CachedSourceRegistry}">
                                          <CollectionView.ItemTemplate>
                                                 <DataTemplate x:DataType="model:CachedSourceRegistryEntry">
                                                        <VerticalStackLayout Spacing="2" Padding="0,6">
                                                               <Label Text="{Binding SourceName}" FontAttributes="Bold" />
                                                               <Label Text="{Binding Endpoint, StringFormat='Endpoint: {0}'}" />
                                                               <Label Text="{Binding State, StringFormat='State: {0}'}" />
                                                               <Label Text="{Binding RegistryKey, StringFormat='Key: {0}'}" />
                                                               <Label Text="{Binding LastSeenDisplay, StringFormat='Last seen: {0}'}" />
                                                        </VerticalStackLayout>
                                                 </DataTemplate>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsAboutSectionSelected}" Spacing="8">
                                   <Label Text="About" FontAttributes="Bold" FontSize="20" />
                                   <Label Text="{Binding AppName}" FontAttributes="Bold" />
                                   <Label Text="{Binding AppVersionBuild}" />
                                   <Label Text="{Binding NdiSdkVersion}" TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>
                     </VerticalStackLayout>
              </Grid>
        </ScrollView>

        <!-- Edit-server modal overlay (#292): dialog over a dimmed scrim; state lives in the ViewModel. -->
        <Grid IsVisible="{Binding IsEditServerDialogOpen}"
                 BackgroundColor="{DynamicResource ScrimBackground}">
               <Border BackgroundColor="{DynamicResource CardBackground}"
                          Stroke="{DynamicResource BorderColor}"
                          StrokeShape="RoundRectangle 12"
                          Padding="20"
                          WidthRequest="420"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">
                      <VerticalStackLayout Spacing="10">
                             <Label Text="Edit discovery server" FontAttributes="Bold" FontSize="18" />
                             <Entry Placeholder="Display name (optional)"
                                       Text="{Binding EditServerDisplayName}" />
                             <Entry Placeholder="Hostname or IP"
                                       Text="{Binding EditServerHost}"
                                       Keyboard="Url" />
                             <Entry Placeholder="Port (default 5959)"
                                       Text="{Binding EditServerPort}"
                                       Keyboard="Numeric" />
                             <Label Text="{Binding EditServerValidationMessage}"
                                       TextColor="{DynamicResource ErrorRed}" />
                             <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                    <Button Text="Cancel" Command="{Binding CancelEditDiscoveryServerCommand}" />
                                    <Button Text="Save" Command="{Binding SaveEditedDiscoveryServerCommand}" />
                             </HorizontalStackLayout>
                      </VerticalStackLayout>
               </Border>
        </Grid>
    </Grid>
</ContentPage>
