<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand colours -->
    <Color x:Key="Primary">#2B7CB8</Color>
    <Color x:Key="PrimaryDark">#1A5A8C</Color>
    <Color x:Key="PrimaryLight">#5BA3D9</Color>
    <Color x:Key="Secondary">#DFE8F0</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray900">#212121</Color>

    <!-- Semantic colours — overridden at runtime by MauiAppearanceService for light/dark -->
    <Color x:Key="PageBackground">#1E1E2E</Color>
    <Color x:Key="CardBackground">#2A2A3E</Color>
    <Color x:Key="ShellBackground">#1C1C1E</Color>
    <Color x:Key="ShellForeground">#FFFFFF</Color>
    <Color x:Key="ShellUnselected">#8E8E93</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#AAAACC</Color>

</ResourceDictionary>
