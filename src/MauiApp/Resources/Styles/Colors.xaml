<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         FIXED BRAND PALETTE  —  never changed at runtime
         ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="PrimaryDark">#1A5A8C</Color>
    <Color x:Key="PrimaryLight">#5BA3D9</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="ErrorRed">#F44336</Color>
    <Color x:Key="SuccessGreen">#4CAF50</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         SEMANTIC COLOR KEYS  —  all overridden at runtime by
         MauiAppearanceService.  Every element in the app MUST use
         DynamicResource on one of these keys — never hardcode hex.
         Default values below are the DARK theme baseline.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Accent (changes with AccentColorOption) -->
    <Color x:Key="Primary">#2B7CB8</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!-- Page / surface -->
    <Color x:Key="PageBackground">#1E1E2E</Color>
    <Color x:Key="CardBackground">#2A2A3E</Color>
    <Color x:Key="InputBackground">#33334A</Color>
    <Color x:Key="ControlBackground">Transparent</Color>
    <Color x:Key="ScrimBackground">#99000000</Color>

    <!-- Shell chrome -->
    <Color x:Key="ShellBackground">#1C1C1E</Color>
    <Color x:Key="ShellForeground">#FFFFFF</Color>
    <Color x:Key="ShellTitleColor">#FFFFFF</Color>
    <Color x:Key="ShellTabSelected">#FFFFFF</Color>
    <Color x:Key="ShellTabUnselected">#8E8E93</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#AAAACC</Color>
    <Color x:Key="TextPlaceholder">#666680</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>

    <!-- Borders / dividers -->
    <Color x:Key="BorderColor">#3A3A5C</Color>
    <Color x:Key="DividerColor">#2E2E4A</Color>

</ResourceDictionary>
